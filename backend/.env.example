# Copie este arquivo para .env e preencha os valores

# URL de conexão com o banco PostgreSQL (gerada pelo Railway)
DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Chave secreta para gerar tokens JWT (use qualquer texto longo e aleatório)
JWT_SECRET=troque_isso_por_um_texto_secreto_longo

# Porta do servidor (Railway define automaticamente)
PORT=3001
